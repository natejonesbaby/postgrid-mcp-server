# PostGrid Print & Mail API key (required)
# Starts with test_sk_ for test mode or live_sk_ for live mode
POSTGRID_PRINT_API_KEY=test_sk_your_key_here

# PostGrid Address Verification API key (optional - needed for address tools)
POSTGRID_VERIFY_API_KEY=test_sk_your_key_here

# Safety gate: must be "true" to allow live API keys (required for live mode)
POSTGRID_CONFIRM_LIVE_MODE=false
